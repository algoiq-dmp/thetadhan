{
  "name": "thetadhan-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create thetadhan-db",
    "db:migrate": "wrangler d1 execute thetadhan-db --local --file=src/db/schema.sql",
    "db:migrate:prod": "wrangler d1 execute thetadhan-db --remote --file=src/db/schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "otplib": "^12.0.1"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  }
}
